<div class="admin-list-header">
  <h1>Authors <span style="font-size:0.8rem;font-weight:400;color:#888">(<%= total %>)</span></h1>
  <a class="admin-btn admin-btn--primary" href="/admin/authors/new">+ New Author</a>
</div>

<% if (deleted) { %>
<div class="admin-flash admin-flash--success">Author deleted.</div>
<% } %>

<form class="admin-filter-form" method="get" action="/admin/authors">
  <input type="text" name="q" value="<%= q %>" placeholder="Search name or username…">
  <button type="submit" class="admin-btn">Search</button>
  <% if (q) { %><a class="admin-btn" href="/admin/authors">Clear</a><% } %>
</form>

<table class="admin-table">
  <thead>
    <tr>
      <th style="width:44px"></th>
      <th>Display Name</th>
      <th>Username</th>
      <th>Articles</th>
      <th>Blog posts</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% authors.forEach(function(author) { %>
    <tr>
      <td><img class="admin-thumb admin-thumb--small" src="<%= author.photo || '/uploads/defaults/avatar.png' %>" alt=""></td>
      <td><a href="/admin/authors/<%= author.id %>/edit"><%= author.display_name || '—' %></a></td>
      <td><%= author.username %></td>
      <td><%= author.article_count %></td>
      <td><%= author.blog_count %></td>
      <td>
        <a class="admin-btn" href="/admin/authors/<%= author.id %>/edit">Edit</a>
      </td>
    </tr>
    <% }) %>
    <% if (!authors.length) { %>
    <tr><td colspan="6" style="text-align:center;color:#888;padding:2rem">No authors found<% if (q) { %> matching "<%= q %>"<% } %>.</td></tr>
    <% } %>
  </tbody>
</table>

<% if (totalPages > 1) { %>
<div class="admin-pagination">
  <% if (page > 1) { %><a class="admin-btn" href="/admin/authors?page=<%= page-1 %>&q=<%= encodeURIComponent(q) %>">← Prev</a><% } %>
  <span>Page <%= page %> of <%= totalPages %></span>
  <% if (page < totalPages) { %><a class="admin-btn" href="/admin/authors?page=<%= page+1 %>&q=<%= encodeURIComponent(q) %>">Next →</a><% } %>
</div>
<% } %>
