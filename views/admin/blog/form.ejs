<script>window.ADMIN_MODULE = 'blog';</script>

<div class="admin-edit-header">
  <h1><%= post ? `Edit: ${post.title}` : 'New Blog Post' %></h1>
  <% if (post && post.id) { %>
  <div class="admin-view-tabs">
    <button type="button" class="admin-view-tab admin-view-tab--active" id="tabEdit" onclick="switchTab('edit')">Edit</button>
    <button type="button" class="admin-view-tab" id="tabView" onclick="switchTab('view')">View</button>
  </div>
  <% } %>
</div>

<% if (typeof saved !== 'undefined' && saved) { %>
<div class="admin-flash admin-flash--success">Saved successfully.</div>
<% } %>

<% if (errors && errors.length) { %>
<div class="admin-form-errors"><% errors.forEach(function(e) { %><p><%= e %></p><% }) %></div>
<% } %>

<% if (post && post.id) { %>
<div id="viewPanel" style="display:none">
  <iframe src="/blog/<%= post.slug %>" id="postPreviewFrame"
          style="width:100%;height:calc(100vh - 140px);border:1px solid #e0e0e0;border-radius:4px;background:#fff"
          title="Post preview"></iframe>
</div>
<% } %>

<div id="editPanel">
<form method="post" action="<%= post && post.id ? `/admin/blog/${post.id}` : '/admin/blog' %>"
      class="admin-form" enctype="multipart/form-data">

  <div class="admin-form-row">
    <label style="flex:2">
      Title *
      <input type="text" name="title" value="<%= (post && post.title) || '' %>" required>
    </label>
    <% if (locals.adminUser?.isSuperAdmin) { %>
    <label>
      Slug
      <input type="text" name="slug" value="<%= (post && post.slug) || '' %>" placeholder="auto-generated">
      <small style="color:#c0392b;font-size:0.75rem">⚠️ Changing slug breaks existing links.</small>
    </label>
    <% } else { %>
    <input type="hidden" name="slug" value="<%= (post && post.slug) || '' %>">
    <% } %>
  </div>

  <label>
    Excerpt <span class="admin-form-hint">(optional — shown in list view)</span>
    <textarea name="excerpt" rows="2" style="resize:vertical"><%= (post && post.excerpt) || '' %></textarea>
  </label>

  <label>
    Body *
    <textarea name="body" class="tinymce" rows="20"><%= (post && post.body) || '' %></textarea>
  </label>

  <label>
    Tags <span class="admin-form-hint">(comma-separated)</span>
    <input type="text" name="tags" value="<%= (post && post.tags) ? post.tags.join(', ') : '' %>"
           placeholder="e.g. film, music, books, interview, poetry, cinema, Assam">
  </label>

  <div class="form-group">
    <label style="display:block;margin-bottom:8px;font-weight:600">Featured Image</label>

    <% if (post && post.featured_image) { %>
    <div id="imgPreview" style="margin-bottom:10px;display:flex;align-items:center;gap:12px">
      <img src="<%= post.featured_image.replace(/\.jpg$/, '-sm.jpg') %>" alt="" style="width:80px;height:60px;object-fit:cover;border-radius:3px;box-shadow:1px 2px 6px rgba(0,0,0,.15)">
      <div>
        <span style="font-size:0.82rem;color:#666"><%= post.featured_image.split('/').pop() %></span><br>
        <label style="font-size:0.82rem;color:#c0392b;cursor:pointer;font-weight:normal">
          <input type="checkbox" name="featured_image_remove" value="1" onchange="document.getElementById('imgPreview').style.opacity=this.checked?'0.4':'1'">
          Remove image
        </label>
      </div>
    </div>
    <% } %>

    <input type="file" name="featured_image" id="featuredImageFile" accept="image/jpeg,image/png,image/webp,image/gif">
    <small style="color:#888;font-size:0.75rem;display:block;margin-top:4px">JPG/PNG/WebP/GIF · resized to 1200px (full) + 400px (thumbnail)</small>

    <label style="font-size:0.82rem;color:#555;display:block;margin-top:10px">
      Caption
      <input type="text" name="featured_image_caption" value="<%= (post && post.featured_image_caption) || '' %>"
             placeholder="Optional caption displayed with the image">
    </label>
  </div>

  <div class="form-group">
    <label style="display:block;margin-bottom:6px;font-weight:600">Video URL <span class="admin-form-hint">(optional)</span></label>
    <input type="url" name="video_url" value="<%= (post && post.video_url) || '' %>"
           placeholder="Paste YouTube, X.com or Facebook video URL">
    <small style="color:#888;font-size:0.75rem;display:block;margin-top:4px">
      Supported: YouTube (youtube.com/watch, youtu.be, /shorts/),
      X/Twitter (x.com/*/status/*),
      Facebook (facebook.com/watch or /videos/)
    </small>
  </div>

  <div class="admin-form-row">
    <div class="form-group" style="flex:1">
      <label style="display:block;margin-bottom:6px;font-weight:600">Author <span class="admin-form-hint">(byline displayed on post)</span></label>
      <input type="hidden" name="author_id" id="authorId" value="<%= (post && post.author_id) || '' %>">
      <div style="position:relative">
        <input type="text" id="authorSearch" autocomplete="off"
               value="<%= (post && post.author_name) ? post.author_name : '' %>"
               placeholder="Type name to search authors…"
               style="width:100%">
        <div id="authorDropdown" class="autocomplete-dropdown" style="display:none;position:absolute;z-index:100;width:100%;background:#fff;border:1px solid #ccc;border-top:none;border-radius:0 0 4px 4px;max-height:200px;overflow-y:auto"></div>
      </div>
      <% if (post && post.author_name) { %>
      <small style="color:#666;font-size:0.78rem">Current: <strong><%= post.author_name %></strong> — type to change</small>
      <% } %>
    </div>
    <label>
      Publish Date <span class="admin-form-hint">(leave blank for now)</span>
      <input type="datetime-local" name="published_at"
             value="<%= (post && post.published_at) ? new Date(post.published_at).toISOString().slice(0,16) : '' %>">
    </label>
  </div>

  <div style="margin-top:1.5rem;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <button type="submit" name="submit_action" value="draft" class="admin-btn">Save Draft</button>
    <button type="submit" name="submit_action" value="published" class="admin-btn admin-btn--primary">Publish</button>
    <a class="admin-btn" href="/admin/blog">Cancel</a>
    <% if (post) { %>
    <span style="margin-left:auto;font-size:0.82rem;color:#888">
      Status: <strong style="color:<%= post.status === 'published' ? '#2e7d32' : '#888' %>"><%= post.status || 'draft' %></strong>
    </span>
    <% } %>
  </div>

</form>
</div>

<script>
(function () {
  var searchInput  = document.getElementById('authorSearch');
  var dropdown     = document.getElementById('authorDropdown');
  var authorIdHidden = document.getElementById('authorId');
  if (!searchInput) return;

  var debounceTimer;
  searchInput.addEventListener('input', function () {
    clearTimeout(debounceTimer);
    var q = searchInput.value.trim();
    if (q.length < 2) { dropdown.style.display = 'none'; return; }
    debounceTimer = setTimeout(async function () {
      try {
        var res = await fetch('/admin/authors/search?q=' + encodeURIComponent(q));
        var authors = await res.json();
        if (!authors.length) { dropdown.style.display = 'none'; return; }
        dropdown.innerHTML = authors.map(function (a) {
          var label = a.display_name || a.username;
          return '<div class="autocomplete-item" data-id="' + a.id + '" data-name="' + label.replace(/"/g, '&quot;') + '" style="padding:8px 12px;cursor:pointer;font-size:0.9rem">' + label + '</div>';
        }).join('');
        dropdown.style.display = 'block';
        dropdown.querySelectorAll('.autocomplete-item').forEach(function (item) {
          item.addEventListener('mousedown', function (e) {
            e.preventDefault();
            authorIdHidden.value = item.dataset.id;
            searchInput.value    = item.dataset.name;
            dropdown.style.display = 'none';
          });
          item.addEventListener('mouseover', function () { item.style.background = '#f0eefb'; });
          item.addEventListener('mouseout',  function () { item.style.background = ''; });
        });
      } catch (_) { dropdown.style.display = 'none'; }
    }, 250);
  });

  searchInput.addEventListener('blur', function () {
    setTimeout(function () { dropdown.style.display = 'none'; }, 200);
  });

  // clear author_id if user manually clears the text
  searchInput.addEventListener('change', function () {
    if (!searchInput.value.trim()) authorIdHidden.value = '';
  });
})();
</script>

<% if (post && post.id) { %>
<script>
function switchTab(tab) {
  var editPanel = document.getElementById('editPanel');
  var viewPanel = document.getElementById('viewPanel');
  var tabEdit   = document.getElementById('tabEdit');
  var tabView   = document.getElementById('tabView');
  if (tab === 'view') {
    editPanel.style.display = 'none';
    viewPanel.style.display = 'block';
    tabEdit.classList.remove('admin-view-tab--active');
    tabView.classList.add('admin-view-tab--active');
    // reload iframe each time so it reflects the latest saved version
    var frame = document.getElementById('postPreviewFrame');
    frame.src = frame.src;
  } else {
    viewPanel.style.display = 'none';
    editPanel.style.display = 'block';
    tabView.classList.remove('admin-view-tab--active');
    tabEdit.classList.add('admin-view-tab--active');
  }
}
</script>
<% } %>
