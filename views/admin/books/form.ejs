<h1><%= book ? `Edit Book: ${book.title}` : 'New Book' %></h1>

<% if (errors && errors.length) { %>
<div class="admin-form-errors"><% errors.forEach(function(e) { %><p><%= e %></p><% }) %></div>
<% } %>

<form method="post" action="<%= book && book.id ? `/admin/books/${book.id}` : '/admin/books' %>" class="admin-form">

  <div class="admin-form-row">
    <label>Title *<input type="text" name="title" value="<%= (book && book.title) || '' %>" required></label>
    <label>Slug<input type="text" name="slug" value="<%= (book && book.slug) || '' %>" placeholder="auto-generated"></label>
  </div>

  <label>Subtitle<input type="text" name="subtitle" value="<%= (book && book.subtitle) || '' %>"></label>

  <label>Description<textarea name="description" rows="6"><%= (book && book.description) || '' %></textarea></label>

  <div class="admin-form-row">
    <label>Cover Image URL<input type="url" name="cover_image" value="<%= (book && book.cover_image) || '' %>" placeholder="https://…">
      <% if (book && book.cover_image) { %><img src="<%= book.cover_image.replace(/\.jpg$/, '-sm.jpg') %>" alt="" style="max-width:60px;max-height:84px;margin-top:6px;display:block;border-radius:2px"><% } %>
    </label>
    <label>Cover Alt Text<input type="text" name="cover_image_alt" value="<%= (book && book.cover_image_alt) || '' %>"></label>
  </div>

  <div class="admin-form-row">
    <label>Price (INR)<input type="number" name="price" step="0.01" min="0" value="<%= (book && book.price) || '' %>"></label>
    <label>Buy URL<input type="url" name="buy_url" value="<%= (book && book.buy_url) || '' %>" placeholder="https://…"></label>
  </div>

  <div class="admin-form-row">
    <label>ISBN<input type="text" name="isbn" value="<%= (book && book.isbn) || '' %>"></label>
    <label>ISBN-13<input type="text" name="isbn13" value="<%= (book && book.isbn13) || '' %>"></label>
  </div>

  <div class="admin-form-row">
    <label>Pages<input type="number" name="pages" min="1" value="<%= (book && book.pages) || '' %>"></label>
    <label>Published Year<input type="number" name="published_year" min="1000" max="2100" value="<%= (book && book.published_year) || '' %>"></label>
  </div>

  <div class="admin-form-row">
    <label>Language
      <input type="text" name="language" value="<%= (book && book.language) || 'English' %>">
    </label>
    <label>Edition<input type="text" name="edition" value="<%= (book && book.edition) || '' %>"></label>
  </div>

  <div class="admin-form-row">
    <label>Format
      <select name="format">
        <% ['paperback','hardcover','ebook','audio'].forEach(function(fmt) { %>
        <option value="<%= fmt %>" <%= (book && book.format === fmt) ? 'selected' : '' %>><%= fmt.charAt(0).toUpperCase() + fmt.slice(1) %></option>
        <% }) %>
      </select>
    </label>
    <label>Status
      <select name="status">
        <option value="active"   <%= (!book || book.status === 'active')   ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= (book && book.status === 'inactive')  ? 'selected' : '' %>>Inactive</option>
      </select>
    </label>
  </div>

  <label>Tags (comma-separated)<input type="text" name="tags" value="<%= (book && book.tags) ? (Array.isArray(book.tags) ? book.tags.join(', ') : book.tags) : '' %>"></label>

  <label>Publisher
    <select name="publisher_id">
      <option value="">— None —</option>
      <% publishers.forEach(function(p) { %>
      <option value="<%= p.id %>" <%= (book && book.publisher_id == p.id) ? 'selected' : '' %>><%= p.name %></option>
      <% }) %>
    </select>
  </label>

  <label class="admin-checkbox" style="margin-bottom:1rem">
    <input type="checkbox" name="is_featured" value="1" <%= (book && book.is_featured) ? 'checked' : '' %>>
    <span>Featured book</span>
  </label>

  <%# ── Authors: tag autocomplete ── %>
  <div class="form-group" style="margin-bottom:1.25rem">
    <label style="display:block;margin-bottom:6px;font-weight:600">Authors</label>
    <div class="author-tags" id="authorTags">
      <% if (book && book.authors && book.authors.length > 0) { %>
        <% book.authors.forEach(function(a) { %>
        <span class="tag-chip" data-id="<%= a.id %>">
          <%= a.name %><% if (a.role && a.role !== 'author') { %> (<%= a.role %>)<% } %>
          <button type="button" class="tag-remove" onclick="removeAuthor(this)">×</button>
          <input type="hidden" name="author_ids[]" value="<%= a.id %>">
          <input type="hidden" name="author_roles[]" value="<%= a.role || 'author' %>">
        </span>
        <% }) %>
      <% } %>
    </div>
    <div class="author-search-wrap">
      <input type="text" id="authorSearch" placeholder="Type 2+ chars to search authors…" autocomplete="off">
      <div id="authorDropdown" class="autocomplete-dropdown" style="display:none"></div>
    </div>
    <small style="color:#888">Type to search, click to add. Multiple authors supported.</small>
  </div>

  <%# ── Categories: pill toggles ── %>
  <div class="form-group" style="margin-bottom:1.25rem">
    <label style="display:block;margin-bottom:6px;font-weight:600">Categories</label>
    <div class="category-pills" id="categoryPills">
      <% categories.forEach(function(cat) { %>
      <% const isSelected = selectedCategories.includes(cat.id); %>
      <label class="cat-pill-label <%= isSelected ? 'selected' : '' %>">
        <input type="checkbox"
               name="category_ids[]"
               value="<%= cat.id %>"
               <%= isSelected ? 'checked' : '' %>
               style="display:none"
               onchange="this.parentElement.classList.toggle('selected', this.checked)">
        <%= cat.name %>
      </label>
      <% }) %>
    </div>
    <small style="color:#888">Click to select/deselect</small>
  </div>

  <div>
    <button type="submit" class="admin-btn admin-btn--primary"><%= book && book.id ? 'Save Changes' : 'Create Book' %></button>
    <a class="admin-btn" href="/admin/books">Cancel</a>
  </div>
</form>

<script>
(function () {
  const authorSearch   = document.getElementById('authorSearch');
  const authorDropdown = document.getElementById('authorDropdown');
  const authorTags     = document.getElementById('authorTags');

  const addedIds = new Set(
    [...document.querySelectorAll('[name="author_ids[]"]')].map(i => i.value)
  );

  authorSearch.addEventListener('input', async function () {
    const q = authorSearch.value.trim();
    if (q.length < 2) { authorDropdown.style.display = 'none'; return; }

    try {
      const res = await fetch('/admin/book-authors/search?q=' + encodeURIComponent(q));
      const authors = await res.json();
      if (!authors.length) { authorDropdown.style.display = 'none'; return; }

      authorDropdown.innerHTML = authors.map(function (a) {
        return '<div class="autocomplete-item" data-id="' + a.id + '" data-name="' + a.name.replace(/"/g, '&quot;') + '">'
          + a.name
          + (a.nationality ? ' <small>' + a.nationality + '</small>' : '')
          + '</div>';
      }).join('');
      authorDropdown.style.display = 'block';

      authorDropdown.querySelectorAll('.autocomplete-item').forEach(function (item) {
        item.addEventListener('click', function () {
          const id   = item.dataset.id;
          const name = item.dataset.name;
          if (addedIds.has(id)) { authorSearch.value = ''; authorDropdown.style.display = 'none'; return; }
          addedIds.add(id);

          const chip = document.createElement('span');
          chip.className = 'tag-chip';
          chip.dataset.id = id;
          chip.innerHTML = name
            + '<button type="button" class="tag-remove" onclick="removeAuthor(this)">×</button>'
            + '<input type="hidden" name="author_ids[]" value="' + id + '">'
            + '<input type="hidden" name="author_roles[]" value="author">';
          authorTags.appendChild(chip);

          authorSearch.value = '';
          authorDropdown.style.display = 'none';
        });
      });
    } catch (e) { authorDropdown.style.display = 'none'; }
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.author-search-wrap')) authorDropdown.style.display = 'none';
  });

  window.removeAuthor = function (btn) {
    const chip = btn.closest('.tag-chip');
    addedIds.delete(chip.dataset.id);
    chip.remove();
  };
})();
</script>
