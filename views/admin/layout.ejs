<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> — Assam Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<%
  const su    = locals.adminUser?.isSuperAdmin;
  const perms = locals.adminUser?.permissions || {};
  const canStories  = su || perms.stories?.can_read;
  const canPages    = su || perms.pages?.can_read;
  const canBooks    = su || perms.books?.can_read;
  const canSettings = su;
%>
<header class="admin-header">
  <nav class="admin-nav">

    <a href="/admin/articles" class="admin-nav__brand">
      <span class="brand-assam">Assam</span><span class="brand-portal">.org</span>
      <span class="brand-admin">Admin</span>
    </a>

    <ul class="admin-nav__list">

      <% if (canStories) { %>
      <li class="admin-nav__item">
        <a href="/admin/articles" class="admin-nav__link">
          Stories
          <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="currentColor" aria-hidden="true"><path d="M0 0l5 6 5-6z"/></svg>
        </a>
        <ul class="admin-nav__dropdown">
          <li><a href="/admin/articles"><span class="nav-icon">📄</span> All Stories</a></li>
          <% if (su || perms.stories?.can_create) { %>
          <li><a href="/admin/articles/new"><span class="nav-icon">✏️</span> + New Story</a></li>
          <% } %>
          <li class="nav-divider"></li>
          <li><a href="/admin/authors"><span class="nav-icon">👤</span> Story Authors</a></li>
          <% if (su || perms.authors?.can_create) { %>
          <li><a href="/admin/authors/new"><span class="nav-icon">➕</span> + New Author</a></li>
          <% } %>
          <% if (su || perms.comments?.can_read) { %>
          <li class="nav-divider"></li>
          <li><a href="/admin/comments"><span class="nav-icon">💬</span> Comments</a></li>
          <% } %>
        </ul>
      </li>
      <% } %>

      <% if (canPages) { %>
      <li class="admin-nav__item">
        <a href="/admin/pages" class="admin-nav__link">
          Pages
          <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="currentColor" aria-hidden="true"><path d="M0 0l5 6 5-6z"/></svg>
        </a>
        <ul class="admin-nav__dropdown">
          <li><a href="/admin/pages"><span class="nav-icon">📃</span> All Pages</a></li>
          <% if (su || perms.pages?.can_create) { %>
          <li><a href="/admin/pages/new"><span class="nav-icon">✏️</span> + New Page</a></li>
          <% } %>
        </ul>
      </li>
      <% } %>

      <% if (canBooks) { %>
      <li class="admin-nav__item">
        <a href="/admin/books" class="admin-nav__link">
          Books
          <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="currentColor" aria-hidden="true"><path d="M0 0l5 6 5-6z"/></svg>
        </a>
        <ul class="admin-nav__dropdown">
          <li><a href="/admin/books"><span class="nav-icon">📚</span> All Books</a></li>
          <% if (su || perms.books?.can_create) { %>
          <li><a href="/admin/books/new"><span class="nav-icon">✏️</span> + New Book</a></li>
          <% } %>
          <li class="nav-divider"></li>
          <li><a href="/admin/book-authors"><span class="nav-icon">👤</span> Book Authors</a></li>
          <% if (su || perms.books?.can_create) { %>
          <li><a href="/admin/book-authors/new"><span class="nav-icon">➕</span> + New Author</a></li>
          <% } %>
          <li class="nav-divider"></li>
          <li><a href="/admin/book-publishers"><span class="nav-icon">🏢</span> Publishers</a></li>
          <% if (su || perms.books?.can_create) { %>
          <li><a href="/admin/book-publishers/new"><span class="nav-icon">➕</span> + New Publisher</a></li>
          <% } %>
        </ul>
      </li>
      <% } %>

      <% if (canSettings) { %>
      <li class="admin-nav__item">
        <a href="/admin/settings" class="admin-nav__link">
          Settings
          <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="currentColor" aria-hidden="true"><path d="M0 0l5 6 5-6z"/></svg>
        </a>
        <ul class="admin-nav__dropdown">
          <li><a href="/admin/settings"><span class="nav-icon">⚙️</span> Site Settings</a></li>
          <li><a href="/admin/menu"><span class="nav-icon">☰</span> Menu Items</a></li>
          <li class="nav-divider"></li>
          <li><a href="/admin/users"><span class="nav-icon">👥</span> Admin Users</a></li>
          <li class="nav-divider"></li>
          <li>
            <form method="post" action="/admin/logout" class="nav-logout-form">
              <button type="submit"><span class="nav-icon">🚪</span> Logout</button>
            </form>
          </li>
        </ul>
      </li>
      <% } %>

    </ul>

    <div class="admin-nav__user">
      <% if (locals.adminUser) { %>
      <span class="admin-nav__username"><%= locals.adminUser.displayName %></span>
      <% if (locals.adminUser.roles && locals.adminUser.roles[0]) { %>
      <span class="admin-nav__role-badge"><%= locals.adminUser.roles[0] %></span>
      <% } %>
      <% } %>
      <% if (!canSettings) { %>
      <form method="post" action="/admin/logout" class="nav-logout-form">
        <button type="submit" class="admin-nav__logout-btn">Logout</button>
      </form>
      <% } %>
    </div>

  </nav>
</header>

<main class="admin-main">
  <%- body %>
</main>

</body>
</html>
