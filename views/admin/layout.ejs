<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <header class="admin-header">
    <span class="admin-header__brand">Assam Portal — Admin</span>
    <nav class="admin-header__nav">
      <%
        const au = typeof adminUser !== 'undefined' ? adminUser : null;
        const su = au && au.isSuperAdmin;
        const p  = (au && au.permissions) || {};
      %>

      <% if (su || (p.stories && p.stories.can_read)) { %>
        <a href="/admin/articles">Stories</a>
      <% } %>

      <% if (su || (p.pages && p.pages.can_read)) { %>
        <a href="/admin/pages">Pages</a>
      <% } %>

      <% if (su || (p.authors && p.authors.can_read)) { %>
        <a href="/admin/authors">Authors</a>
      <% } %>

      <% if (su || (p.settings && p.settings.can_read)) { %>
        <a href="/admin/menu">Menu</a>
        <a href="/admin/settings">Settings</a>
      <% } %>

      <% if (su || (p.books && p.books.can_read)) { %>
        <a href="/admin/books">Books</a>
      <% } %>

      <% if (su || (p.users && p.users.can_read)) { %>
        <a href="/admin/users">Users</a>
      <% } %>

      <form method="post" action="/admin/logout" class="admin-header__logout">
        <button type="submit">Logout<% if (au) { %> (<%= au.displayName %>)<% } %></button>
      </form>
    </nav>
  </header>
  <main class="admin-main">
    <%- body %>
  </main>
</body>
</html>
