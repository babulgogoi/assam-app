<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> — Assam Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
  <script src="/vendor/tinymce/tinymce.min.js" referrerpolicy="origin"></script>
  <script>
  tinymce.init({
    selector: 'textarea.tinymce',
    license_key: 'gpl',
    promotion: false,
    height: 520,
    menubar: true,
    plugins: [
      'advlist','autolink','lists','link','image','charmap','preview',
      'anchor','searchreplace','visualblocks','code','fullscreen',
      'insertdatetime','media','table','help','wordcount','codesample'
    ],
    toolbar:
      'undo redo | styles | bold italic underline | ' +
      'alignleft aligncenter alignright | ' +
      'bullist numlist outdent indent | ' +
      'link image media table | ' +
      'blockquote codesample | ' +
      'removeformat code fullscreen | help',
    style_formats: [
      { title: 'Heading 2', block: 'h2' },
      { title: 'Heading 3', block: 'h3' },
      { title: 'Heading 4', block: 'h4' },
      { title: 'Paragraph', block: 'p' },
      { title: 'Blockquote', block: 'blockquote' },
      { title: 'Code', inline: 'code' },
    ],
    images_upload_url: '/admin/upload-image?module=' + (window.ADMIN_MODULE || 'articles'),
    images_upload_handler: async (blobInfo, progress) => {
      const formData = new FormData();
      formData.append('file', blobInfo.blob(), blobInfo.filename());
      const mod = window.ADMIN_MODULE || 'articles';
      const response = await fetch('/admin/upload-image?module=' + mod, { method: 'POST', body: formData });
      if (!response.ok) throw new Error('Upload failed');
      const data = await response.json();
      return data.location;
    },
    content_style: `
      body { font-family: Georgia, serif; font-size: 16px; line-height: 1.7;
             max-width: 760px; margin: 16px auto; color: #333; }
      h2   { font-size: 1.35rem; border-bottom: 1px solid #eee; padding-bottom: 6px; margin-top: 28px; }
      h3   { font-size: 1.1rem; margin-top: 20px; }
      blockquote { border-left: 3px solid #1A00AC; margin: 0; padding: 8px 16px;
                   background: #f9fbf9; color: #555; }
      img  { max-width: 100%; height: auto; }
      table { border-collapse: collapse; width: 100%; }
      td, th { border: 1px solid #ddd; padding: 8px; }
    `,
    forced_root_block: 'p',
    setup: (editor) => { editor.on('change', () => editor.save()); }
  });
  </script>
</head>
<body class="admin-body">
<%
  const su    = locals.adminUser?.isSuperAdmin;
  const perms = locals.adminUser?.permissions || {};
  const ap    = locals.activePath || '';
  const canStories  = su || perms.stories?.can_read;
  const canPages    = su || perms.pages?.can_read;
  const canBooks    = su || perms.books?.can_read;
  const canBlog     = su || perms.blog?.can_read;
  const canAuthors  = su || perms.authors?.can_read;
  const canUsers    = su || perms.users?.can_read;
  const canSettings = su || perms.settings?.can_read;
%>
<header class="admin-header">
  <nav class="admin-nav">

    <a href="/admin" class="admin-nav__brand">
      Assam<span class="brand-dot">.org</span>
      <span class="brand-chip">ADMIN</span>
    </a>

    <% if (canPages || canStories || canBlog) { %>
    <div class="admin-nav__dropdown">
      <button type="button" class="admin-nav__trigger <%= ['/admin/pages','/admin/page-topics','/admin/articles','/admin/blog'].some(p => ap.startsWith(p)) ? 'active' : '' %>">
        Content <span class="caret">▾</span>
      </button>
      <div class="admin-nav__menu">
        <% if (canPages) { %>
        <a href="/admin/pages" class="<%= ap.startsWith('/admin/pages') ? 'active' : '' %>">
          📄 Pages
          <small>Encyclopedia</small>
        </a>
        <a href="/admin/page-topics" class="<%= ap.startsWith('/admin/page-topics') ? 'active' : '' %>">
          🗂 Topics
          <small>Page categories</small>
        </a>
        <% } %>
        <% if (canStories) { %>
        <a href="/admin/articles" class="<%= ap.startsWith('/admin/articles') ? 'active' : '' %>">
          📰 News
          <small>Articles</small>
        </a>
        <% } %>
        <% if (canBlog) { %>
        <a href="/admin/blog" class="<%= ap.startsWith('/admin/blog') ? 'active' : '' %>">
          ✍️ The Assam Review
          <small>Blog posts</small>
        </a>
        <% } %>
      </div>
    </div>
    <% } %>

    <% if (canBooks) { %>
    <div class="admin-nav__dropdown">
      <button type="button" class="admin-nav__trigger <%= ap.startsWith('/admin/book') ? 'active' : '' %>">
        Books <span class="caret">▾</span>
      </button>
      <div class="admin-nav__menu">
        <a href="/admin/books" class="<%= ap.startsWith('/admin/books') ? 'active' : '' %>">
          📚 All Books
          <small>Catalogue</small>
        </a>
        <a href="/admin/book-authors" class="<%= ap.startsWith('/admin/book-authors') ? 'active' : '' %>">
          👤 Authors
          <small>Book authors</small>
        </a>
        <a href="/admin/book-publishers" class="<%= ap.startsWith('/admin/book-publishers') ? 'active' : '' %>">
          🏢 Publishers
          <small>Book publishers</small>
        </a>
      </div>
    </div>
    <% } %>

    <% if (canUsers || canAuthors) { %>
    <div class="admin-nav__dropdown">
      <button type="button" class="admin-nav__trigger <%= ['/admin/users','/admin/authors'].some(p => ap.startsWith(p)) ? 'active' : '' %>">
        People <span class="caret">▾</span>
      </button>
      <div class="admin-nav__menu">
        <% if (canUsers) { %>
        <a href="/admin/users" class="<%= ap.startsWith('/admin/users') ? 'active' : '' %>">
          🔑 Users
          <small>Admin accounts</small>
        </a>
        <% } %>
        <% if (canAuthors) { %>
        <a href="/admin/authors" class="<%= ap.startsWith('/admin/authors') ? 'active' : '' %>">
          ✍️ Authors
          <small>Byline authors</small>
        </a>
        <% } %>
      </div>
    </div>
    <% } %>

    <% if (canSettings) { %>
    <div class="admin-nav__dropdown">
      <button type="button" class="admin-nav__trigger <%= ['/admin/settings','/admin/menu','/admin/redirects'].some(p => ap.startsWith(p)) ? 'active' : '' %>">
        System <span class="caret">▾</span>
      </button>
      <div class="admin-nav__menu">
        <a href="/admin/analytics" class="<%= ap.startsWith('/admin/analytics') ? 'active' : '' %>">
          📊 Analytics
          <small>Views &amp; clicks</small>
        </a>
        <a href="/admin/settings" class="<%= ap.startsWith('/admin/settings') ? 'active' : '' %>">
          ⚙️ Settings
          <small>Site configuration</small>
        </a>
        <a href="/admin/menu" class="<%= ap.startsWith('/admin/menu') ? 'active' : '' %>">
          🔗 Menu
          <small>Navigation items</small>
        </a>
        <a href="/admin/redirects" class="<%= ap.startsWith('/admin/redirects') ? 'active' : '' %>">
          ↪️ Redirects
          <small>URL redirects</small>
        </a>
      </div>
    </div>
    <% } %>

    <div class="admin-nav__user">
      <% if (locals.adminUser) { %>
      <span class="admin-nav__username"><%= locals.adminUser.displayName || locals.adminUser.username %></span>
      <% if (locals.adminUser.roles && locals.adminUser.roles[0]) { %>
      <span class="admin-nav__role"><%= locals.adminUser.roles[0] %></span>
      <% } %>
      <% } %>
      <form method="post" action="/admin/logout" class="nav-logout-form">
        <button type="submit" class="admin-nav__logout">Logout</button>
      </form>
    </div>

  </nav>
</header>

<main class="admin-main">
  <%- body %>
</main>

</body>
</html>
