<div class="admin-list-header">
  <h1>Menu</h1>
  <a class="admin-btn admin-btn--primary" href="/admin/menu/new">+ New Item</a>
</div>

<% if (flash) { %>
<div class="admin-flash admin-flash--<%= flash.type %>"><%= flash.message %></div>
<% } %>

<p class="admin-form-hint" style="margin-bottom:16px;">
  Changes appear on the public site immediately after saving.
  Items with no URL (no page selected and no custom URL entered) are hidden from the nav even if active.
</p>

<table class="admin-table">
  <thead>
    <tr>
      <th>Sort</th>
      <th>Label</th>
      <th>Resolves to</th>
      <th>Active</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% items.forEach(function (item) {
         let resolvedUrl = '';
         if (item.page_id && item.page_title) {
           resolvedUrl = '→ /page/…  (page: ' + item.page_title + ')';
         } else if (item.custom_url) {
           resolvedUrl = item.custom_url;
         } else {
           resolvedUrl = '⚠ No URL set — will not appear in nav';
         }
    %>
    <tr>
      <td><%= item.sort_order %></td>
      <td><a href="/admin/menu/<%= item.id %>/edit"><%= item.label %></a></td>
      <td style="font-size:0.8rem;color:<%= (!item.page_id && !item.custom_url) ? '#c0392b' : '#555' %>;">
        <%= resolvedUrl %>
      </td>
      <td>
        <% if (item.is_active) { %>
        <span class="admin-badge admin-badge--published">Active</span>
        <% } else { %>
        <span class="admin-badge admin-badge--draft">Inactive</span>
        <% } %>
      </td>
      <td style="display:flex;gap:6px;">
        <a href="/admin/menu/<%= item.id %>/edit" class="admin-btn" style="padding:4px 10px;font-size:0.78rem;">Edit</a>
        <form method="post" action="/admin/menu/<%= item.id %>/delete" onsubmit="return confirm('Delete this menu item?');">
          <button type="submit" class="admin-btn admin-btn--danger" style="padding:4px 10px;font-size:0.78rem;">Del</button>
        </form>
      </td>
    </tr>
    <% }) %>
    <% if (!items.length) { %>
    <tr><td colspan="5">No menu items found. Add one above.</td></tr>
    <% } %>
  </tbody>
</table>
