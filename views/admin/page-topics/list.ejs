<% if (saved) { %><div class="admin-flash admin-flash--success">Topics saved.</div><% } %>
<% if (deleted) { %><div class="admin-flash admin-flash--success">Topic deleted.</div><% } %>

<div class="admin-list-header">
  <h1>Page Topics <span style="color:#888;font-weight:400;font-size:1rem">(<%= topics.length %>)</span></h1>
</div>

<div style="background:#f9f9f9;border:1px solid #e0e0e0;border-radius:6px;padding:1.25rem;margin-bottom:1.5rem">
  <h3 style="margin:0 0 0.75rem;font-size:0.9rem;text-transform:uppercase;color:#666;letter-spacing:.5px">Add New Topic</h3>
  <form method="post" action="/admin/page-topics" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end">
    <label style="font-size:0.82rem;font-weight:600">Icon
      <input type="text" name="icon" placeholder="🗺️" style="width:56px;text-align:center;font-size:1.1rem">
    </label>
    <label style="flex:1;min-width:130px;font-size:0.82rem;font-weight:600">Name *
      <input type="text" name="name" placeholder="Topic name" required>
    </label>
    <label style="flex:2;min-width:180px;font-size:0.82rem;font-weight:600">Description
      <input type="text" name="description" placeholder="Short description (optional)">
    </label>
    <label style="width:70px;font-size:0.82rem;font-weight:600">Order
      <input type="number" name="sort_order" value="0" style="width:65px">
    </label>
    <button type="submit" class="admin-btn admin-btn--primary">+ Add Topic</button>
  </form>
</div>

<table class="admin-table">
  <thead>
    <tr>
      <th>Icon</th>
      <th>Name</th>
      <th>Slug</th>
      <th>Description</th>
      <th>Order</th>
      <th>Pages</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% topics.forEach(function(topic) { %>
    <tr>
      <td style="width:60px;text-align:center">
        <span style="font-size:1.3rem"><%= topic.icon || '' %></span>
      </td>
      <td><strong><%= topic.name %></strong></td>
      <td><code style="font-size:0.75rem;color:#888"><%= topic.slug %></code></td>
      <td style="color:#666;font-size:0.85rem"><%= topic.description || '—' %></td>
      <td style="text-align:center"><%= topic.sort_order %></td>
      <td style="text-align:center">
        <a href="/research/<%= topic.slug %>"><%= topic.page_count %></a>
      </td>
      <td>
        <button class="admin-btn"
                onclick="openTopicEdit('<%= topic.id %>','<%= topic.icon || '' %>','<%= topic.name.replace(/'/g, '\\\'') %>','<%= (topic.description || '').replace(/'/g, '\\\'') %>','<%= topic.sort_order %>')">
          Edit
        </button>
        <form method="post" action="/admin/page-topics/<%= topic.id %>/delete" style="display:inline"
              onsubmit="return confirm('Delete topic <%= topic.name %>? Pages will keep their content but lose the topic.')">
          <button class="admin-btn admin-btn--danger">Delete</button>
        </form>
      </td>
    </tr>
    <% }) %>
    <% if (!topics.length) { %>
    <tr><td colspan="7" style="color:#888;text-align:center;padding:2rem">No topics yet.</td></tr>
    <% } %>
  </tbody>
</table>

<!-- Edit modal -->
<div id="topicEditModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:2000;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:8px;padding:2rem;width:480px;max-width:95vw;box-shadow:0 8px 32px rgba(0,0,0,.3)">
    <h3 style="margin:0 0 1.25rem">Edit Topic</h3>
    <form id="topicEditForm" method="post" action="" style="display:flex;flex-direction:column;gap:0.75rem">
      <div style="display:flex;gap:8px">
        <label style="font-size:0.82rem;font-weight:600">Icon
          <input type="text" id="editIcon" name="icon" style="width:56px;text-align:center;font-size:1.1rem">
        </label>
        <label style="flex:1;font-size:0.82rem;font-weight:600">Name *
          <input type="text" id="editName" name="name" required>
        </label>
        <label style="width:70px;font-size:0.82rem;font-weight:600">Order
          <input type="number" id="editOrder" name="sort_order" style="width:65px">
        </label>
      </div>
      <label style="font-size:0.82rem;font-weight:600">Description
        <input type="text" id="editDescription" name="description">
      </label>
      <div style="display:flex;gap:8px;margin-top:0.5rem">
        <button type="submit" class="admin-btn admin-btn--primary">Save</button>
        <button type="button" class="admin-btn" onclick="closeTopicEdit()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function openTopicEdit(id, icon, name, desc, order) {
  document.getElementById('topicEditForm').action = '/admin/page-topics/' + id;
  document.getElementById('editIcon').value = icon;
  document.getElementById('editName').value = name;
  document.getElementById('editDescription').value = desc;
  document.getElementById('editOrder').value = order;
  document.getElementById('topicEditModal').style.display = 'flex';
}
function closeTopicEdit() {
  document.getElementById('topicEditModal').style.display = 'none';
}
document.getElementById('topicEditModal').addEventListener('click', function(e) {
  if (e.target === this) closeTopicEdit();
});
</script>
