<script>window.ADMIN_MODULE = 'pages';</script>
<div class="admin-list-header">
  <h1><%= page ? 'Edit Page' : 'New Page' %></h1>
  <% if (page && page.id && page.slug) { %>
  <div class="page-edit-tabs">
    <a href="/page/<%= page.slug %>" target="_blank" rel="noopener" class="page-edit-tab">View →</a>
    <a href="/admin/pages/<%= page.id %>/revisions" class="page-edit-tab">Revisions</a>
  </div>
  <% } %>
</div>

<% if (errors && errors.length) { %>
  <ul class="admin-form-errors">
    <% errors.forEach(function (e) { %><li><%= e %></li><% }) %>
  </ul>
<% } %>

<form class="admin-form" method="post"
      action="<%= page && page.id ? '/admin/pages/' + page.id : '/admin/pages' %>"
      enctype="multipart/form-data">

  <div class="admin-form-row">
    <label>Title *
      <input type="text" name="title" value="<%= page ? page.title : '' %>" required>
    </label>
    <% if (locals.adminUser?.isSuperAdmin) { %>
    <label>Slug <span class="admin-form-hint">(auto-generated from title)</span>
      <input type="text" name="slug" value="<%= page ? page.slug : '' %>">
      <small style="color:#c0392b;font-size:0.75rem">⚠️ Changing slug will break existing links and redirects.</small>
    </label>
    <% } else { %>
    <input type="hidden" name="slug" value="<%= page ? page.slug : '' %>">
    <% } %>
  </div>

  <div class="editors-note-box">
    <label class="editors-note-box__label">📝 Editor's Note
      <small>Visible in Revisions tab — brief note on article status or changes made</small>
    </label>
    <textarea name="editors_note" id="editorsNoteArea" rows="2" maxlength="500"
              class="editors-note-box__input"
              placeholder="e.g. Major restructure — added H2 sections for each dance form. Images still needed."><%= (page && page.editors_note) || '' %></textarea>
    <div class="editors-note-box__footer"><span id="editorNoteCount">0</span>/500</div>
  </div>

  <label>Excerpt <span class="admin-form-hint">(100–150 chars, shown in cards)</span>
    <input type="text" name="excerpt"
           value="<%= (page && page.excerpt) || '' %>"
           maxlength="500"
           placeholder="Brief description of this page…">
  </label>

  <div class="admin-form-row">
    <label>Topic / Category *
      <select name="topic_id" required>
        <option value="">— Select topic —</option>
        <% (typeof topics !== 'undefined' ? topics : []).forEach(function(t) { %>
        <option value="<%= t.id %>" <%= (page && page.topic_id == t.id) ? 'selected' : '' %>>
          <%= t.icon %> <%= t.name %>
        </option>
        <% }) %>
      </select>
    </label>
    <label>Status
      <select name="status">
        <option value="draft"      <%= page && page.status === 'draft'      ? 'selected' : '' %>>Draft</option>
        <option value="published"  <%= !page || page.status === 'published' ? 'selected' : '' %>>Published</option>
      </select>
    </label>
  </div>

  <div class="form-group" style="margin-bottom:1.25rem">
    <label style="display:block;margin-bottom:6px;font-weight:600">
      Data Entry / Editor
      <small style="color:#888;font-weight:400"> — internal record only, not shown on public page</small>
    </label>
    <div class="author-search-wrap" style="position:relative">
      <input type="text" id="authorSearchInput" autocomplete="off"
             placeholder="Type to search authors…"
             value="<%= (page && (page.author_name || page.author_username)) || '' %>">
      <div id="authorDropdown" class="autocomplete-dropdown" style="display:none"></div>
    </div>
    <input type="hidden" name="author_id" id="authorIdInput" value="<%= (page && page.author_id) || '' %>">
  </div>

  <div class="form-group" style="margin-bottom:1.25rem">
    <label class="checkbox-label">
      <input type="checkbox" name="update_needed" id="updateNeeded"
             <%= (page && page.update_needed) ? 'checked' : '' %>>
      <span class="checkbox-label__text">⚠️ Mark as <strong>Update Needed</strong></span>
    </label>
    <div id="updateNoteWrap" style="<%= (page && page.update_needed) ? '' : 'display:none' %>;margin-top:8px">
      <input type="text" name="update_needed_note"
             value="<%= (page && page.update_needed_note) || '' %>"
             placeholder="Optional note — what needs updating?">
    </div>
  </div>

  <div class="form-group cover-image-group">
    <label style="display:block;margin-bottom:6px;font-weight:600">Featured Image</label>
    <div class="cover-preview" id="featuredPreview" style="<%= (page && page.featured_image) ? 'display:flex' : 'display:none' %>">
      <img src="<%= (page && page.featured_image) || '' %>" alt="" width="120"
           id="featuredPreviewImg" style="border-radius:3px;box-shadow:1px 2px 6px rgba(0,0,0,.15)">
      <div class="cover-preview-actions">
        <button type="button" class="btn-remove-cover" onclick="removeFeatured()">× Remove</button>
      </div>
    </div>
    <input type="hidden" name="featured_image_remove" id="featuredImageRemove" value="0">
    <div class="cover-upload-area">
      <input type="file" name="featured_image" id="featuredImageFile"
             accept="image/jpeg,image/png,image/webp" onchange="previewFeatured(this)">
      <label for="featuredImageFile" class="cover-upload-label">
        <%= (page && page.featured_image) ? '📁 Replace image' : '📁 Upload image' %>
      </label>
      <small style="color:#888;font-size:0.75rem">JPG or PNG · shown at top of page</small>
    </div>
    <input type="text" name="featured_image_caption"
           value="<%= (page && page.featured_image_caption) || '' %>"
           placeholder="Image caption (optional)"
           style="margin-top:8px">
  </div>

  <label>Body Content
    <textarea name="body" id="body" class="tinymce" rows="20" required><%- page ? page.body : '' %></textarea>
  </label>

  <label>References &amp; Citations <span class="admin-form-hint">(APA style, one per line)</span>
    <textarea name="references_text" rows="5"
              placeholder="1. Author, A. (Year). Title. Publisher."><%= (page && page.references_text) || '' %></textarea>
  </label>

  <div class="form-group" style="margin-bottom:1.25rem;border:1px solid #e2e2e2;border-radius:6px;padding:1rem">
    <label style="display:block;font-weight:600;margin-bottom:8px">PDF Attachment</label>
    <% if (page && page.pdf_attachment) { %>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;padding:8px 12px;background:#f5f5f5;border-radius:4px" id="pdfCurrentWrap">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
      <a href="<%= page.pdf_attachment %>" target="_blank" style="font-size:0.875rem"><%= page.pdf_label || page.pdf_attachment.split('/').pop() %></a>
      <button type="button" onclick="removePdf()" style="margin-left:auto;background:none;border:none;color:#c00;cursor:pointer;font-size:0.85rem">× Remove</button>
    </div>
    <% } %>
    <input type="hidden" name="pdf_attachment_remove" id="pdfRemove" value="0">
    <div id="pdfUploadArea">
      <input type="file" name="pdf_attachment" id="pdfFile" accept="application/pdf" onchange="showPdfName(this)">
      <label for="pdfFile" class="cover-upload-label" style="margin-top:4px">
        <%= (page && page.pdf_attachment) ? '📄 Replace PDF' : '📄 Upload PDF' %>
      </label>
      <small style="color:#888;font-size:0.75rem">PDF only · max 50 MB · shown as download before citations</small>
    </div>
    <div id="pdfNewName" style="font-size:0.85rem;color:#555;margin-top:6px;display:none"></div>
    <input type="text" name="pdf_label"
           value="<%= (page && page.pdf_label) || '' %>"
           placeholder="Document title (e.g. 'Annual Survey Report 2024')"
           style="margin-top:10px">
    <small style="color:#888;font-size:0.75rem">Title shown as the hyperlink — leave blank to use file name</small>
  </div>

  <div style="margin-top:28px;border:1px solid #e2e2e2;border-radius:6px;padding:1rem;background:#fafafa">
    <div class="form-group">
      <label style="font-weight:600;font-size:0.88rem">Revision Note
        <span class="admin-form-hint"> — saved with this revision only, appears in Revisions tab</span>
      </label>
      <input type="text" name="editor_log_note"
             placeholder="e.g. Fixed broken references, added H3 headings for dance styles">
      <small style="color:#888;font-size:0.75rem">Creates a revision history entry. Leave blank if no note needed.</small>
    </div>
  </div>

  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:1rem">
    <button type="submit" class="admin-btn admin-btn--primary"><%= page && page.id ? 'Save Changes' : 'Create Page' %></button>
    <% if (page && page.id && page.slug) { %>
    <a class="admin-btn" href="/page/<%= page.slug %>" target="_blank" rel="noopener">View →</a>
    <% } %>
    <a class="admin-btn" href="/admin/pages">Cancel</a>
  </div>
</form>

<script>
(function () {
  var authorInput    = document.getElementById('authorSearchInput');
  var authorDropdown = document.getElementById('authorDropdown');
  var authorIdInput  = document.getElementById('authorIdInput');

  authorInput.addEventListener('input', async function () {
    var q = authorInput.value.trim();
    if (q.length < 2) { authorDropdown.style.display = 'none'; return; }
    try {
      var res     = await fetch('/admin/authors/search?q=' + encodeURIComponent(q));
      var authors = await res.json();
      if (!authors.length) { authorDropdown.style.display = 'none'; return; }
      authorDropdown.innerHTML = authors.map(function (a) {
        var name = a.display_name || a.username;
        return '<div class="autocomplete-item" data-id="' + a.id + '" data-name="' + name.replace(/"/g,'&quot;') + '">'
          + name + (a.username ? ' <small style="color:#aaa">@' + a.username + '</small>' : '')
          + '</div>';
      }).join('');
      authorDropdown.style.display = 'block';
      authorDropdown.querySelectorAll('.autocomplete-item').forEach(function (item) {
        item.addEventListener('click', function () {
          authorIdInput.value  = item.dataset.id;
          authorInput.value    = item.dataset.name;
          authorDropdown.style.display = 'none';
        });
      });
    } catch (_) { authorDropdown.style.display = 'none'; }
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.author-search-wrap')) authorDropdown.style.display = 'none';
  });
})();

(function () {
  function previewFeatured(input) {
    if (!input.files || !input.files[0]) return;
    const reader = new FileReader();
    reader.onload = function (e) {
      document.getElementById('featuredPreviewImg').src = e.target.result;
      document.getElementById('featuredPreview').style.display = 'flex';
      document.getElementById('featuredImageRemove').value = '0';
    };
    reader.readAsDataURL(input.files[0]);
  }
  function removeFeatured() {
    document.getElementById('featuredPreview').style.display = 'none';
    document.getElementById('featuredImageFile').value = '';
    document.getElementById('featuredImageRemove').value = '1';
  }
  window.previewFeatured = previewFeatured;
  window.removeFeatured  = removeFeatured;
})();

function showPdfName(input) {
  var el = document.getElementById('pdfNewName');
  if (input.files && input.files[0]) {
    el.textContent = 'Selected: ' + input.files[0].name;
    el.style.display = 'block';
  } else {
    el.style.display = 'none';
  }
}
function removePdf() {
  document.getElementById('pdfRemove').value = '1';
  var wrap = document.getElementById('pdfCurrentWrap');
  if (wrap) wrap.style.display = 'none';
  document.getElementById('pdfFile').value = '';
}
window.showPdfName = showPdfName;
window.removePdf   = removePdf;

document.getElementById('updateNeeded').addEventListener('change', function () {
  document.getElementById('updateNoteWrap').style.display = this.checked ? 'block' : 'none';
});

(function () {
  var area  = document.getElementById('editorsNoteArea');
  var count = document.getElementById('editorNoteCount');
  if (area && count) {
    count.textContent = area.value.length;
    area.addEventListener('input', function () { count.textContent = area.value.length; });
  }
})();
</script>

<style>
.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
}
.checkbox-label input[type=checkbox] {
  width: 16px;
  height: 16px;
  accent-color: #1A00AC;
  flex-shrink: 0;
}
.checkbox-label__text { font-size: 0.9rem; }
</style>
