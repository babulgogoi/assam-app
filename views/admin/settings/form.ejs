<h1>Settings</h1>

<form class="admin-form" method="post" action="/admin/settings">
  <label>
    Featured Articles Category <span class="admin-form-hint">(category used for the "Featured Articles" sidebar block on the homepage)</span>
    <input type="text" name="featured_category" value="<%= featuredCategory %>" required>
  </label>

  <label>
    Footer HTML <span class="admin-form-hint">(raw HTML, rendered as-is at the bottom of every public page)</span>
    <textarea name="footer_html" rows="20" style="font-family: monospace;"><%= footerHtml || '' %></textarea>
  </label>

  <label class="admin-form-checkbox">
    <input type="checkbox" name="publish_custom_html_enabled" value="1"
           <%= settings && settings.publish_custom_html_enabled ? 'checked' : '' %>>
    Show custom HTML block on /books/publish page
  </label>

  <label>
    Publish Page — Custom HTML Block <span class="admin-form-hint">(raw HTML/CSS/Bootstrap — rendered just above the contact CTA)</span>
    <textarea name="publish_custom_html" rows="16" style="font-family:monospace;font-size:0.85rem;"><%= settings && settings.publish_custom_html ? settings.publish_custom_html : '' %></textarea>
  </label>

  <button type="submit" class="admin-btn admin-btn--primary">Save</button>
</form>
