<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% if (process.env.NODE_ENV === 'production' && process.env.GA4_MEASUREMENT_ID) { %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= process.env.GA4_MEASUREMENT_ID %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '<%= process.env.GA4_MEASUREMENT_ID %>');
    </script>
  <% } %>
  <title><%= typeof title !== 'undefined' ? title : 'Assam Portal' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof adsenseClientId !== 'undefined' && adsenseClientId) { %>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= adsenseClientId %>" crossorigin="anonymous"></script>
  <% } %>
</head>
<body>
  <%- include('partials/ads-header') %>
  <%- include('partials/header') %>

  <main class="site-main">
    <%- body %>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/header.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmxuJ9A74hf0N3MKkuRKGQo//C/Y" crossorigin="anonymous"></script>
</body>
</html>
