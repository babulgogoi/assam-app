<header class="site-header">
  <div class="site-header__inner">
    <a class="site-logo-link" href="/">
      <img src="/uploads/branding/assam-logo.png" alt="assam.org" class="site-logo-img" height="44" loading="eager">
    </a>

    <button class="site-header__menu-toggle" id="menuToggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="siteNav">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-header__nav" id="siteNav">
      <% var navItems = (typeof menuItems !== 'undefined' && menuItems) ? menuItems : []; %>
      <% navItems.forEach(function (item) { %>
        <% if (item.url) { %>
        <a href="<%= item.url %>"
           class="<%= (locals.currentUrl === item.url || (item.url !== '/' && locals.currentUrl && locals.currentUrl.startsWith(item.url))) ? 'nav-active' : '' %>">
          <%= item.label %>
        </a>
        <% } %>
      <% }) %>
    </nav>
    <form class="site-header__search" action="/search" method="get">
      <input type="search" name="q" placeholder="Search..." value="<%= typeof q !== 'undefined' ? q : '' %>">
    </form>
  </div>
</header>
