<main class="book-detail">
  <div class="book-detail__top">
    <div class="book-detail__cover">
      <% if (book.cover_image) { %>
      <img src="<%= book.cover_image %>" alt="<%= book.cover_image_alt || book.title %>" width="200">
      <% } else { %>
      <div class="book-detail__no-cover"><%= book.title.slice(0, 2).toUpperCase() %></div>
      <% } %>
    </div>

    <div class="book-detail__info">
      <h1><%= book.title %></h1>
      <% if (book.subtitle) { %><p class="book-detail__subtitle"><%= book.subtitle %></p><% } %>

      <% if (book.authors && book.authors.length > 0) { %>
      <p class="book-detail__authors">
        by
        <% book.authors.forEach(function(a, i) { %>
        <a href="/books/author/<%= a.slug %>"><%= a.name %></a><% if (a.role && a.role !== 'author') { %> (<%= a.role %>)<% } %><% if (i < book.authors.length - 1) { %>, <% } %>
        <% }) %>
      </p>
      <% } %>

      <% if (book.avg_rating) { %>
      <div class="book-detail__rating">
        <% for (let i = 1; i <= 5; i++) { %>
        <span class="<%= i <= Math.round(book.avg_rating) ? 'star-filled' : 'star-empty' %>">★</span>
        <% } %>
        <strong><%= book.avg_rating %></strong> (<%= book.rating_count %> ratings)
      </div>
      <% } %>

      <table class="book-detail__meta">
        <% if (book.publisher_name) { %>
        <tr><th>Publisher</th><td><a href="/books/publisher/<%= book.publisher_slug %>"><%= book.publisher_name %></a></td></tr>
        <% } %>
        <% if (book.published_year) { %><tr><th>Year</th><td><%= book.published_year %></td></tr><% } %>
        <% if (book.pages) { %><tr><th>Pages</th><td><%= book.pages %></td></tr><% } %>
        <% if (book.language) { %><tr><th>Language</th><td><%= book.language %></td></tr><% } %>
        <% if (book.format) { %><tr><th>Format</th><td><%= book.format.charAt(0).toUpperCase() + book.format.slice(1) %></td></tr><% } %>
        <% if (book.isbn) { %><tr><th>ISBN</th><td><%= book.isbn %></td></tr><% } %>
        <% if (book.isbn13) { %><tr><th>ISBN-13</th><td><%= book.isbn13 %></td></tr><% } %>
        <% if (book.edition) { %><tr><th>Edition</th><td><%= book.edition %></td></tr><% } %>
      </table>

      <% if (book.price) { %><p class="book-detail__price">₹<%= book.price %></p><% } %>

      <% if (book.buy_url) { %>
      <a href="<%= book.buy_url %>" target="_blank" rel="noopener noreferrer" class="btn-buy">Buy Now →</a>
      <% } %>

      <% if (book.author_interview_url || book.blog_url || book.video_url) { %>
      <div class="book-extra-links">
        <h4>More about this book</h4>
        <% if (book.author_interview_url) { %>
        <a href="<%= book.author_interview_url %>" target="_blank" rel="noopener"
           class="book-extra-link book-extra-link--interview">🎤 Author Interview</a>
        <% } %>
        <% if (book.blog_url) { %>
        <a href="<%= book.blog_url %>" target="_blank" rel="noopener"
           class="book-extra-link book-extra-link--blog">📝 Read Blog / Review</a>
        <% } %>
        <% if (book.video_url) { %>
        <a href="<%= book.video_url %>" target="_blank" rel="noopener"
           class="book-extra-link book-extra-link--video">▶ Watch Video</a>
        <% } %>
      </div>
      <% } %>

      <div class="book-rate">
        <p>Rate this book:</p>
        <div class="rate-stars" data-book-id="<%= book.id %>">
          <% for (let i = 1; i <= 5; i++) { %>
          <span class="rate-star" data-rating="<%= i %>">★</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <% if (book.description) { %>
  <section class="book-detail__description">
    <h2>About this book</h2>
    <div class="book-description-body"><%- book.description %></div>
  </section>
  <% } %>

  <% if (book.categories && book.categories.length > 0) { %>
  <div class="book-detail__categories">
    <strong>Categories:</strong>
    <% book.categories.forEach(function(cat) { %>
    <a href="/books/category/<%= cat.slug %>" class="book-cat-tag"><%= cat.name %></a>
    <% }) %>
  </div>
  <% } %>

  <% if (book.tags && book.tags.length > 0) { %>
  <div class="book-detail__tags">
    <% book.tags.forEach(function(tag) { %>
    <span class="book-tag"><%= tag %></span>
    <% }) %>
  </div>
  <% } %>

  <% if (relatedBooks && relatedBooks.length > 0) { %>
  <section class="book-related-section">
    <h2 class="book-related-heading">You May Also Like</h2>
    <div class="book-related-grid">
      <% relatedBooks.forEach(function(rb) { %>
      <a href="/book/<%= rb.slug %>" class="book-related-card">
        <div class="book-related-card__cover">
          <% if (rb.cover_image) { %>
          <img src="<%= rb.cover_image.replace(/\.jpg$/, '-md.jpg') %>"
               alt="<%= rb.title %>" loading="lazy" width="160" height="220">
          <% } else { %>
          <div class="book-related-card__no-cover"><%= rb.title.slice(0, 2).toUpperCase() %></div>
          <% } %>
        </div>
        <div class="book-related-card__info">
          <h3><%= rb.title %></h3>
          <% if (rb.authors && rb.authors.length > 0) { %>
          <p class="book-related-card__author"><%= rb.authors[0].name %></p>
          <% } %>
          <% if (rb.price) { %>
          <p class="book-related-card__price">₹<%= rb.price %></p>
          <% } %>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>

<script>
document.querySelectorAll('.rate-star').forEach(function(star) {
  star.addEventListener('click', async function() {
    const rating = parseInt(this.dataset.rating, 10);
    const bookId = this.closest('.rate-stars').dataset.bookId;
    try {
      await fetch('/book/' + bookId + '/rate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rating }),
      });
      this.closest('.rate-stars').querySelectorAll('.rate-star').forEach(function(s, i) {
        s.style.color = i < rating ? '#f59e0b' : '#ccc';
      });
    } catch (e) {}
  });
});
</script>
