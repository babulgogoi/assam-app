<main class="books-main">
  <div class="book-detail-search">
    <a href="/books" class="book-detail-back">← All Books</a>
    <form action="/books/search" method="GET" class="books-search-form">
      <div class="books-search-input-wrap">
        <input type="text" name="q" placeholder="Search books…" aria-label="Search books">
        <button type="submit" aria-label="Search">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <% if (locals.adminUser && (adminUser.isSuperAdmin || (adminUser.permissions && adminUser.permissions.books && adminUser.permissions.books.can_update))) { %>
  <div class="contextual-edit-bar">
    <a href="/admin/book-authors/<%= author.id %>/edit" class="contextual-edit-btn">✏️ Edit this author</a>
  </div>
  <% } %>

  <div class="books-author-header">
    <% if (author.photo) { %>
    <img src="<%= author.photo %>" alt="<%= author.name %>"
         class="books-author-photo" width="100" height="100">
    <% } else { %>
    <div class="books-author-avatar"><%= author.name.slice(0, 2).toUpperCase() %></div>
    <% } %>
    <div class="books-author-meta">
      <h1><%= author.name %></h1>
      <% if (author.nationality) { %>
      <p class="books-author-nationality"><%= author.nationality %><% if (author.birth_year) { %> · b. <%= author.birth_year %><% } %></p>
      <% } %>
      <% if (author.website || author.wikipedia_url) { %>
      <div class="books-author-links" style="margin-top:8px">
        <% if (author.website) { %><a href="<%= author.website %>" target="_blank" rel="noopener" class="books-author-website">🌐 Website</a><% } %>
        <% if (author.wikipedia_url) { %><a href="<%= author.wikipedia_url %>" target="_blank" rel="noopener" class="books-author-website">Wikipedia</a><% } %>
      </div>
      <% } %>
    </div>
  </div>

  <% if (author.bio) { %>
  <div class="books-author-bio"><%- author.bio %></div>
  <% } %>

  <h2 class="books-author-books-heading">
    Books by <%= author.name %>
    <span class="books-count-badge"><%= books.length %></span>
  </h2>

  <% if (books.length > 0) { %>
  <div class="books-catalogue-grid">
    <% books.forEach(function(book) { %>
    <div class="books-catalogue-item">
      <a href="/book/<%= book.slug %>" class="books-catalogue-cover">
        <% if (book.cover_image) { %>
        <img src="<%= book.cover_image.replace(/\.jpg$/, '-md.jpg') %>"
             alt="<%= book.title %>" loading="lazy" width="200" height="280">
        <% } else { %>
        <div class="books-catalogue-cover__placeholder"><%= book.title.slice(0, 2).toUpperCase() %></div>
        <% } %>
      </a>
      <div class="books-catalogue-info">
        <h3><a href="/book/<%= book.slug %>"><%= book.title %></a></h3>
        <% if (book.published_year) { %>
        <p class="books-catalogue-author"><%= book.published_year %></p>
        <% } %>
        <div class="books-catalogue-meta">
          <% if (book.price) { %><span class="books-catalogue-price">₹<%= book.price %></span><% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <p class="books-empty">No books listed for this author yet.</p>
  <% } %>

  <% if (typeof blogPostsByAuthor !== 'undefined' && blogPostsByAuthor.length > 0) { %>
  <h2 class="books-author-books-heading">
    Blog posts by <%= author.name %>
    <span class="books-count-badge"><%= blogPostsByAuthor.length %></span>
  </h2>
  <ul class="books-author-posts">
    <% blogPostsByAuthor.forEach(function(p) { %>
    <li>
      <a href="/blog/<%= p.slug %>"><%= p.title %></a>
      <% if (p.published_at) { %>
      <time datetime="<%= new Date(p.published_at).toISOString() %>">
        <%= new Date(p.published_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %>
      </time>
      <% } %>
    </li>
    <% }) %>
  </ul>
  <% } %>
</main>
