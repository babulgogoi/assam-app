<main class="publish-page">

  <section class="publish-hero">
    <div class="home-section__inner">
      <h1 class="publish-hero__headline">Publish Your Book — From Manuscript to Assam's Bookshelf</h1>
      <p class="publish-hero__subhead">
        Editorial support, design, print, ebook/Kindle conversion, and placement directly in assam.org's
        own book catalogue — with a built-in regional audience.
      </p>
      <div class="publish-hero__ctas">
        <a href="mailto:<%= settings.publish_contact_email || 'webmaster@assam.org' %>?subject=Book%20Publishing%20Inquiry"
           class="btn-publish-primary">Get a Free Quote</a>
        <a href="#howItWorks" class="btn-publish-secondary">See How It Works</a>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section__inner">
      <h2 class="home-section__title">📖 Why Publish With Us</h2>
      <div class="publish-why-grid">
        <div class="publish-why-card">
          <span class="publish-why-card__icon">✍️</span>
          <h3>In-House Editorial &amp; Design</h3>
          <p>Our own editorial and design team handles your manuscript — not outsourced.</p>
        </div>
        <div class="publish-why-card">
          <span class="publish-why-card__icon">🗣️</span>
          <h3>Multilingual</h3>
          <p>Assamese, English, Bodo, and other Northeast regional languages all welcome.</p>
        </div>
        <div class="publish-why-card">
          <span class="publish-why-card__icon">📚</span>
          <h3>Built-In Distribution</h3>
          <p>Your book joins assam.org's existing catalogue of 580+ titles with a ready regional audience.</p>
        </div>
        <div class="publish-why-card">
          <span class="publish-why-card__icon">💰</span>
          <h3>No Upfront Distribution Cost</h3>
          <p>We list and promote your book at no extra charge — we only earn when your book sells.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section publish-how" id="howItWorks">
    <div class="home-section__inner">
      <h2 class="home-section__title">⚙️ How It Works</h2>
      <div class="publish-steps">
        <div class="publish-step">
          <span class="publish-step__num">1</span>
          <div><h3>Get in Touch</h3><p>Email us your manuscript and book details to start the conversation.</p></div>
        </div>
        <div class="publish-step">
          <span class="publish-step__num">2</span>
          <div><h3>Get a Custom Quote</h3><p>We review your submission and send a no-obligation quote for production costs.</p></div>
        </div>
        <div class="publish-step">
          <span class="publish-step__num">3</span>
          <div><h3>We Edit, Design &amp; Lay Out</h3><p>Our team handles editing, cover design, and interior layout.</p></div>
        </div>
        <div class="publish-step">
          <span class="publish-step__num">4</span>
          <div><h3>Print-Ready &amp; Ebook Files</h3><p>Receive print-ready files plus an ebook/Kindle conversion.</p></div>
        </div>
        <div class="publish-step">
          <span class="publish-step__num">5</span>
          <div><h3>Listed &amp; Selling</h3><p>Your book goes live on assam.org and digital channels — you earn on every sale, we take a commission only on what we sell.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section__inner">
      <h2 class="home-section__title">📦 Packages &amp; Add-ons</h2>
      <div class="publish-packages">
        <div class="publish-package-card">
          <h3>Basic</h3>
          <ul>
            <li>Proofreading</li>
            <li>Basic cover design</li>
            <li>Print-ready PDF</li>
          </ul>
          <p class="publish-package-card__price">Starting from — get exact quote</p>
        </div>
        <div class="publish-package-card publish-package-card--featured">
          <span class="publish-package-card__badge">Most Popular</span>
          <h3>Standard</h3>
          <ul>
            <li>Copyediting</li>
            <li>Custom cover design</li>
            <li>Interior layout</li>
            <li>Print + ebook/Kindle conversion</li>
          </ul>
          <p class="publish-package-card__price">Starting from — get exact quote</p>
        </div>
        <div class="publish-package-card">
          <h3>Premium</h3>
          <ul>
            <li>Everything in Standard</li>
            <li>Developmental editing</li>
            <li>Marketing push via assam.org channels</li>
            <li>Priority catalogue placement</li>
          </ul>
          <p class="publish-package-card__price">Starting from — get exact quote</p>
        </div>
      </div>

      <div class="publish-addons">
        <h3>Add-ons</h3>
        <div class="publish-addons-grid">
          <span>✓ Extra editing round</span>
          <span>✓ Custom illustration/artwork</span>
          <span>✓ ISBN registration</span>
          <span>✓ Translation services</span>
          <span>✓ Author bio/photo page</span>
          <span>✓ Expedited turnaround</span>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section publish-distribution">
    <div class="home-section__inner">
      <h2 class="home-section__title">🚚 Distribution &amp; Commission</h2>
      <p class="publish-distribution__text">
        Your book goes live in the assam.org catalogue and ebook/Kindle channels at no extra cost to you.
        Instead of charging upfront for distribution, we take a commission per sale — commission details
        are included in your personalized quote.
      </p>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section__inner">
      <h2 class="home-section__title">❓ FAQ</h2>
      <div class="publish-faq">
        <details class="publish-faq__item">
          <summary>What languages do you accept manuscripts in?</summary>
          <p>Assamese, English, Bodo, and other Northeast regional languages.</p>
        </details>
        <details class="publish-faq__item">
          <summary>How long does the process take?</summary>
          <p>Timeline depends on package and manuscript length — we'll share an estimate with your custom quote.</p>
        </details>
        <details class="publish-faq__item">
          <summary>Who owns the rights to my book?</summary>
          <p>You retain full rights to your work. We provide production and distribution services only.</p>
        </details>
        <details class="publish-faq__item">
          <summary>How and when do I get paid for sales?</summary>
          <p>Payment terms and schedule are included in your custom quote.</p>
        </details>
        <details class="publish-faq__item">
          <summary>What's the minimum print run?</summary>
          <p>This depends on your chosen package — ask us for details in your quote.</p>
        </details>
        <details class="publish-faq__item">
          <summary>What file formats do you accept for manuscripts?</summary>
          <p>.docx and .pdf are accepted via email.</p>
        </details>
        <details class="publish-faq__item">
          <summary>Can I order printed copies for myself separately from catalogue sales?</summary>
          <p>Yes, author copies can be arranged — just mention this when you contact us.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="home-section publish-contact-cta">
    <div class="home-section__inner">
      <h2 class="home-section__title">✉️ Ready to Get Started?</h2>
      <p class="publish-contact-cta__text">
        Email us your manuscript and book details — we'll get back to you with a custom quote, no obligation.
      </p>
      <a href="mailto:<%= settings.publish_contact_email || 'webmaster@assam.org' %>?subject=Book%20Publishing%20Inquiry"
         class="btn-publish-primary btn-publish-primary--large">
        📧 <%= settings.publish_contact_email || 'webmaster@assam.org' %>
      </a>
    </div>
  </section>

</main>
