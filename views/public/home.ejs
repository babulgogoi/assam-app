<div class="homepage">

  <%# ── HERO ─────────────────────────────────────────── %>
  <section class="hero"
    <% if (settings.hero_image) { %>
    style="background-image:url('<%= settings.hero_image %>');"
    <% } else { %>
    style="background:linear-gradient(135deg,#130082 0%,#1A00AC 55%,#6B5CE0 100%);"
    <% } %>>

    <div class="hero__content">
      <% if (settings.hero_headline) { %>
      <h1 class="hero__headline"><%= settings.hero_headline %></h1>
      <% } %>
      <% if (settings.hero_subtext) { %>
      <p class="hero__subtext"><%= settings.hero_subtext %></p>
      <% } %>

      <form action="/books/search" method="GET" class="hero-search-form">
        <input type="text" name="q" placeholder="Search books, topics, research…" aria-label="Search">
        <button type="submit">Search</button>
      </form>

      <div class="hero__ctas">
        <% if (settings.hero_cta_text && settings.hero_cta_url) { %>
        <a href="<%= settings.hero_cta_url %>" class="hero__cta hero__cta--primary"><%= settings.hero_cta_text %></a>
        <% } %>
        <a href="/research" class="hero__cta hero__cta--secondary">Browse Research</a>
      </div>
    </div>

    <div class="hero__stats">
      <div class="hero__stat"><strong>587</strong><span>Books</span></div>
      <div class="hero__stat"><strong>101</strong><span>Research Pages</span></div>
      <div class="hero__stat"><strong>544</strong><span>Stories</span></div>
      <div class="hero__stat"><strong>12</strong><span>Topics</span></div>
    </div>
  </section>

  <%# ── BOOKS ─────────────────────────────────────────── %>
  <section class="home-section home-books">
    <div class="home-section__inner">
      <div class="home-section__header">
        <h2 class="home-section__title"><%= settings.books_section_title || 'Books About Assam' %></h2>
        <a href="/books" class="home-section__viewall">View all books →</a>
      </div>

      <div class="home-books-row">
        <% books.slice(0, 5).forEach(function(book) { %>
        <div class="home-book-card">
          <a href="/book/<%= book.slug %>" class="home-book-card__cover">
            <% if (book.cover_image) { %>
            <img src="<%= book.cover_image.replace(/(\.[^.]+)$/, '-md$1') %>"
                 alt="<%= book.title %>" loading="lazy">
            <% } else { %>
            <div class="home-book-card__placeholder"><%= book.title.slice(0,2).toUpperCase() %></div>
            <% } %>
          </a>
          <div class="home-book-card__info">
            <h3><a href="/book/<%= book.slug %>"><%= book.title %></a></h3>
            <% if (book.authors && book.authors.length > 0) { %>
            <p class="home-book-card__author"><%= book.authors[0].name %></p>
            <% } %>
            <% if (book.price) { %><p class="home-book-card__price">₹<%= book.price %></p><% } %>
          </div>
        </div>
        <% }) %>
      </div>

      <% if (books.length > 5) { %>
      <div class="home-books-row">
        <% books.slice(5, 10).forEach(function(book) { %>
        <div class="home-book-card">
          <a href="/book/<%= book.slug %>" class="home-book-card__cover">
            <% if (book.cover_image) { %>
            <img src="<%= book.cover_image.replace(/(\.[^.]+)$/, '-md$1') %>"
                 alt="<%= book.title %>" loading="lazy">
            <% } else { %>
            <div class="home-book-card__placeholder"><%= book.title.slice(0,2).toUpperCase() %></div>
            <% } %>
          </a>
          <div class="home-book-card__info">
            <h3><a href="/book/<%= book.slug %>"><%= book.title %></a></h3>
            <% if (book.authors && book.authors.length > 0) { %>
            <p class="home-book-card__author"><%= book.authors[0].name %></p>
            <% } %>
            <% if (book.price) { %><p class="home-book-card__price">₹<%= book.price %></p><% } %>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>

      <div class="home-books-footer">
        <a href="/books" class="btn-viewall">Browse all 587 books →</a>
      </div>
    </div>
  </section>

  <%# ── CUSTOM BLOCK 1 ────────────────────────────────── %>
  <% if (settings.custom_block_1_enabled && settings.custom_block_1_html) { %>
  <section class="home-custom-block">
    <div class="home-section__inner"><%- settings.custom_block_1_html %></div>
  </section>
  <% } %>

  <%# ── RESEARCH ───────────────────────────────────────── %>
  <section class="home-section home-research">
    <div class="home-section__inner">
      <div class="home-section__header">
        <h2 class="home-section__title"><%= settings.research_section_title || 'Research & Knowledge' %></h2>
        <a href="/research" class="home-section__viewall">Browse all topics →</a>
      </div>

      <% if (topics && topics.length) { %>
      <div class="home-topics-grid">
        <% topics.forEach(function(topic) { %>
        <a href="/research/<%= topic.slug %>" class="home-topic-card">
          <span class="home-topic-card__icon"><%= topic.icon || '📄' %></span>
          <span class="home-topic-card__name"><%= topic.name %></span>
          <span class="home-topic-card__count"><%= topic.page_count %> <%= topic.page_count === 1 ? 'article' : 'articles' %></span>
        </a>
        <% }) %>
      </div>
      <% } %>

      <% if (latestPages && latestPages.length) { %>
      <div class="home-research-cards">
        <% latestPages.forEach(function(page) { %>
        <article class="home-research-card">
          <a href="/page/<%= page.slug %>"
             class="home-research-card__image<%= page.featured_image ? '' : ' home-research-card__image--placeholder' %>">
            <% if (page.featured_image) { %>
            <img src="<%= page.featured_image %>" alt="<%= page.title %>" loading="lazy">
            <% } else { %>
            <span><%= page.topic_icon || '📄' %></span>
            <% } %>
          </a>
          <div class="home-research-card__body">
            <% if (page.topic_name) { %>
            <span class="home-research-card__topic"><%= page.topic_icon %> <%= page.topic_name %></span>
            <% } %>
            <h3><a href="/page/<%= page.slug %>"><%= page.title %></a></h3>
            <% var excerpt = page.excerpt || (page.body || '').replace(/<[^>]+>/g,'').slice(0,120); %>
            <% if (excerpt) { %><p><%= excerpt %>…</p><% } %>
            <a href="/page/<%= page.slug %>" class="home-research-card__link">Read more →</a>
          </div>
        </article>
        <% }) %>
      </div>
      <% } %>
    </div>
  </section>

  <%# ── CUSTOM BLOCK 2 ────────────────────────────────── %>
  <% if (settings.custom_block_2_enabled && settings.custom_block_2_html) { %>
  <section class="home-custom-block">
    <div class="home-section__inner"><%- settings.custom_block_2_html %></div>
  </section>
  <% } %>

</div>
