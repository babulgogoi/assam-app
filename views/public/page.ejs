<main class="wiki-page">

  <nav class="wiki-breadcrumb">
    <a href="/">Home</a> ›
    <a href="/research">Research</a>
    <% if (page.topic) { %>
    › <a href="/research/<%= page.topic.slug %>"><%= page.topic.icon %> <%= page.topic.name %></a>
    <% } %>
    › <span><%= page.title %></span>
  </nav>

  <% if (locals.adminUser && (adminUser.isSuperAdmin || adminUser.permissions?.pages?.can_update)) { %>
  <div class="contextual-edit-bar">
    <a href="/admin/pages/<%= page.id %>/edit" class="contextual-edit-btn">✏️ Edit this page</a>
    <a href="/admin/page-topics" class="contextual-edit-btn">🏷️ Manage topics</a>
  </div>
  <% } %>

  <div class="wiki-page__layout">
    <div class="wiki-page__main">

      <div class="wiki-page__title-row">
        <h1 class="wiki-page__title"><%= page.title %></h1>
        <div class="wiki-page__tab-btns">
          <a href="/page/<%= page.slug %>" class="wiki-tab-btn wiki-tab-btn--active">Article</a>
          <a href="/page/<%= page.slug %>/revisions" class="wiki-tab-btn">Revisions</a>
        </div>
      </div>

      <% if (page.featured_image) { %>
      <figure class="wiki-page__featured-image">
        <img src="<%= page.featured_image %>" alt="<%= page.title %>" loading="lazy">
        <% if (page.featured_image_caption) { %>
        <figcaption><%= page.featured_image_caption %></figcaption>
        <% } %>
      </figure>
      <% } %>

      <div class="wiki-page__body page-body-content" id="pageBody">
        <%- page.body %>
      </div>

      <% if (page.pdf_attachment) { %>
      <div class="wiki-page__pdf-download">
        <span class="pdf-download-prefix">PDF / Document:</span>
        <a href="<%= page.pdf_attachment %>" target="_blank" rel="noopener" class="pdf-download-link">
          <%= page.pdf_label || page.pdf_attachment.split('/').pop() %>
        </a>
      </div>
      <% } %>

      <% if (page.references_text && page.references_text.trim()) { %>
      <section class="wiki-page__references">
        <h2>References</h2>
        <ol class="references-list">
          <% page.references_text.split('\n').filter(function(r){ return r.trim(); }).forEach(function(ref) { %>
          <li><%= ref.replace(/^\d+\.\s*/, '') %></li>
          <% }) %>
        </ol>
      </section>
      <% } %>

      <% if (page.topic) { %>
      <div class="wiki-page__categories">
        <strong>Category:</strong>
        <a href="/research/<%= page.topic.slug %>" class="wiki-cat-link">
          <%= page.topic.icon %> <%= page.topic.name %>
        </a>
      </div>
      <% } %>

    </div>
  </div>
</main>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var body = document.getElementById('pageBody');
  if (!body) return;

  var headings = body.querySelectorAll('h2, h3');
  if (headings.length < 3) return;

  var ol = document.createElement('ol');
  headings.forEach(function (h, i) {
    var id = 'section-' + (i + 1);
    h.id = id;
    var li = document.createElement('li');
    li.className = h.tagName === 'H3' ? 'toc-sub' : 'toc-main';
    var a = document.createElement('a');
    a.href = '#' + id;
    a.textContent = h.textContent.trim();
    li.appendChild(a);
    ol.appendChild(li);
  });

  var heading = document.createElement('p');
  heading.className = 'page-toc__heading';
  heading.textContent = 'Contents';

  var toc = document.createElement('div');
  toc.className = 'page-toc';
  toc.appendChild(heading);
  toc.appendChild(ol);

  // Insert before the first H2 so any intro text above it renders
  // at full width; the TOC then floats beside the section content.
  // Fallback to firstChild if no H2 exists.
  var firstH2 = body.querySelector('h2');
  body.insertBefore(toc, firstH2 || body.firstChild);
});
</script>
