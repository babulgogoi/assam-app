<div class="search-page">

  <div class="search-page__hero">
    <h1 class="search-page__title">
      <% if (q) { %>Results for "<%= q %>"<% } else { %>Search assam.org<% } %>
    </h1>
    <form class="search-page__form" action="/search" method="get">
      <div class="search-page__input-wrap">
        <input type="search" name="q" value="<%= q %>"
               placeholder="Search articles, topics…"
               autofocus="<%= !q ? 'autofocus' : '' %>"
               autocomplete="off">
        <button type="submit">Search</button>
      </div>
    </form>
  </div>

  <div class="home-layout">
    <div class="home-main">

      <% if (tooShort) { %>
        <p class="search-page__hint">Please enter at least 2 characters.</p>

      <% } else if (!q) { %>
        <p class="search-page__hint">Type a word or phrase above and press Search.</p>

      <% } else if (!articles.length) { %>
        <p class="search-page__hint">No articles found for "<strong><%= q %></strong>". Try a different term.</p>

      <% } else { %>
        <p class="search-page__count"><%= articles.length %> result<%= articles.length === 1 ? '' : 's' %> — page <%= page %> of <%= totalPages %></p>

        <div class="article-grid">
          <% articles.forEach(function (article) { %>
          <article class="article-card">
            <a href="/article/<%= article.slug %>">
              <img class="article-card__image"
                   src="<%= article.featured_image || '/uploads/defaults/at-news.png' %>"
                   alt="<%= article.title %>" loading="lazy">
              <h2 class="article-card__title"><%= article.title %></h2>
            </a>
            <p class="article-meta">
              <% if (article.author_username) { %>by <a href="/author/<%= encodeURIComponent(article.author_username) %>"><%= article.author_name %></a><% } %>
              <% if (article.category) { %> in <a href="/category/<%= encodeURIComponent(article.category) %>"><%= article.category %></a><% } %>
            </p>
            <% if (article.excerpt) { %><p class="article-card__excerpt"><%= article.excerpt %></p><% } %>
          </article>
          <% }) %>
        </div>

        <nav class="pagination">
          <% if (page > 1) { %>
          <a href="/search?q=<%= encodeURIComponent(q) %>&page=<%= page - 1 %>">&laquo; Prev</a>
          <% } %>
          <span>Page <%= page %> of <%= totalPages %></span>
          <% if (page < totalPages) { %>
          <a href="/search?q=<%= encodeURIComponent(q) %>&page=<%= page + 1 %>">Next &raquo;</a>
          <% } %>
        </nav>
      <% } %>

    </div>

    <aside class="home-sidebar">
      <%- include('../partials/sidebar-most-read') %>
    </aside>
  </div>
</div>
